#pragma once

/**
 * @file version.hpp
 * @brief SyncFlow version information (auto-generated by CMake)
 */

#define SYNCFLOW_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define SYNCFLOW_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define SYNCFLOW_VERSION_PATCH @PROJECT_VERSION_PATCH@

#define SYNCFLOW_VERSION_STRING "@PROJECT_VERSION@"
#define SYNCFLOW_VERSION_DESCRIPTION "@PROJECT_DESCRIPTION@"

/// Full version string for display
#define SYNCFLOW_FULL_VERSION "SyncFlow v" SYNCFLOW_VERSION_STRING " (@PROJECT_NAME@)"

/// Git commit hash (if available during build)
#define SYNCFLOW_GIT_COMMIT "@GIT_COMMIT_HASH@"

/// Build timestamp
#define SYNCFLOW_BUILD_TIMESTAMP "@CMAKE_BUILD_TIMESTAMP@"

/// C++ Standard version used
#define SYNCFLOW_CXX_STANDARD @CMAKE_CXX_STANDARD@

namespace syncflow {

/// Get version major number
inline constexpr int version_major() { return SYNCFLOW_VERSION_MAJOR; }

/// Get version minor number
inline constexpr int version_minor() { return SYNCFLOW_VERSION_MINOR; }

/// Get version patch number
inline constexpr int version_patch() { return SYNCFLOW_VERSION_PATCH; }

/// Get full version string
inline constexpr const char* version_string() { return SYNCFLOW_VERSION_STRING; }

}  // namespace syncflow
